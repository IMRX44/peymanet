# ─────────────────────────────────────────────────────────────
# Peymanet environment configuration
# ─────────────────────────────────────────────────────────────

# Database
# Dev/sandbox default: SQLite (zero infra). For production, switch the
# Prisma datasource provider in prisma/schema.prisma to "postgresql"
# and point DATABASE_URL at your Postgres instance, e.g.:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/peymanet?schema=public"
DATABASE_URL="file:./dev.db"

# ─────────────────────────── AI engine ───────────────────────────
# AI_MODE:
#   mock  -> deterministic, schema-valid, offline results (no API key). Default.
#   live  -> call a real provider (selected by AI_PROVIDER below).
#           ("openai" is still accepted as an alias for "live".)
AI_MODE="mock"

# AI_PROVIDER (only when AI_MODE=live). One code path, switched by this one var:
#   openai             -> OpenAI (api.openai.com)
#   openai-compatible  -> any OpenAI-compatible endpoint (reseller / proxy /
#                         gateway / OpenRouter / local LLM). Set OPENAI_BASE_URL.
#   azure              -> Azure OpenAI
#   google             -> Google Gemini
#   anthropic          -> Anthropic Claude
# Set ONLY the block for the provider you chose; the rest can stay empty.
AI_PROVIDER="openai"

# ── OpenAI / OpenAI-compatible ──
OPENAI_API_KEY=""
# Deep-analysis model (risk · negotiation · assistant).
OPENAI_MODEL="gpt-4o"
# Cheaper/faster model for segmentation and lightweight passes.
OPENAI_MODEL_FAST="gpt-4o-mini"
# Base URL for AI_PROVIDER=openai-compatible (reseller / proxy / gateway /
# OpenRouter / local server). Leave empty for real OpenAI.
#   e.g. OPENAI_BASE_URL="https://your-provider.example/v1"
OPENAI_BASE_URL=""
# Optional extra headers some gateways require, as JSON:
#   e.g. OPENAI_HEADERS='{"HTTP-Referer":"https://yourapp.com"}'
OPENAI_HEADERS=""

# ── Google Gemini (AI_PROVIDER=google) ──
GOOGLE_API_KEY=""
# Optional model overrides (defaults: gemini-1.5-pro / gemini-1.5-flash).
GOOGLE_MODEL=""
GOOGLE_MODEL_FAST=""

# ── Anthropic Claude (AI_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=""
# Optional model overrides (defaults: claude-3-5-sonnet-latest / -haiku-latest).
ANTHROPIC_MODEL=""
ANTHROPIC_MODEL_FAST=""

# ── Azure OpenAI (AI_PROVIDER=azure) ──
# Set OPENAI_MODEL / OPENAI_MODEL_FAST to your *deployment* names.
AZURE_RESOURCE_NAME=""
AZURE_API_KEY=""
# Optional:
AZURE_API_VERSION=""
AZURE_BASE_URL=""

# Note: signed-in users can also add their OWN provider key in Settings; a user's
# active key takes precedence over these deployment-level variables.

# Default UI locale: "fa" (RTL) or "en" (LTR)
DEFAULT_LOCALE="fa"

# Secret used to encrypt per-user API keys at rest + sign nothing else.
# Set a strong random value in production (e.g. `openssl rand -hex 32`).
APP_SECRET="change-me-to-a-long-random-string"

# Access control:
#   - New sign-ups start UNAPPROVED and must be approved by an admin (in /admin)
#     before they can use the app.
#   - The first account created on an empty database automatically becomes an
#     approved admin.
#   - Any email listed here (comma-separated) is auto-promoted to an approved
#     admin on sign-up — handy for bootstrapping known admins.
ADMIN_EMAILS=""
